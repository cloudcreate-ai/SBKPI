{
  "name": "sbkpi",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SBKPI：基于 SBTI-test 的调侃向静态站点（测验 + wiki + 扑克图鉴）",
  "scripts": {
    "start": "npm run build && serve dist -l 3000 --no-request-logging",
    "dev": "npm run start",
    "preview": "npm run start",
    "serve": "serve . -l 3000 --no-request-logging",
    "build": "node scripts/build-dist.mjs",
    "deploy": "npm run build && wrangler deploy",
    "release:zip": "node scripts/make-release-zip.mjs"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "serve": "^14.2.4",
    "wrangler": "^4.82.2"
  }
}
